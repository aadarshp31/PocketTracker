{
  "name": "pocket-tracker-server",
  "version": "0.0.0",
  "description": "",
  "main": "server.ts",
  "scripts": {
    "start": "ENV_FILE_PATH=\"${ENV_FILE_PATH:-$HOME/adarsh-envs/PocketTracker/server/.env}\" ts-node server.ts",
    "start:prod": "ENV_FILE_PATH=\"${ENV_FILE_PATH:-$HOME/adarsh-envs/PocketTracker/server/.env}\" node dist/server.js",
    "dev:server": "npm run start",
    "dev:client": "npm --prefix ../client run dev --",
    "dev:full": "concurrently -k -n server,client -c green,blue \"npm run dev:server\" \"npm run dev:client\"",
    "clean": "rm -rf dist",
    "build": "tsc",
    "build:client": "npm --prefix ../client run build:server-public",
    "build:prod": "npm run build && npm run build:client",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "author": "aadarshp31",
  "license": "CC-BY-NC-4.0",
  "dependencies": {
    "@supabase/supabase-js": "^2.47.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "morgan": "^1.10.0",
    "pg": "^8.13.1",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.5",
    "swagger-jsdoc": "^6.2.8",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^5.0.0",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.8.0",
    "concurrently": "^9.2.1"
  }
}
